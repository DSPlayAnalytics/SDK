---
import Base from '~/layouts/Base.astro';
import Button from '~/components/ui/Button.astro';
import Card from '~/components/ui/Card.astro';
import FormError from '~/components/ui/FormError.astro';
import Input from '~/components/ui/Input.astro';
import Section from '~/components/ui/Section.astro';
---
<Base
  title="Recuperar acesso"
  description="Receba um link mágico no seu email pra entrar sem senha."
  noindex={true}
>
  <Section narrow class="flex min-h-[70vh] flex-col justify-center">
    <Card>
      <h1 class="text-2xl font-bold text-white">Recuperar acesso</h1>
      <p class="mt-1 text-sm text-slate-400">
        Digite o email da sua conta. Você vai receber um link que entra
        direto, sem precisar de senha. Vale por 15 minutos.
      </p>

      <form id="form-magic-link" class="mt-6 space-y-4" novalidate>
        <Input id="email" type="email" label="Email" autocomplete="email" required placeholder="voce@empresa.com" />

        <FormError id="erro" />

        <Button type="submit" id="submit" fullWidth data-cta="form-esqueci-senha">Enviar link de acesso</Button>

        <p class="text-center text-sm text-slate-400">
          Lembrou da senha? <a href="/cliente/login" class="text-brand-300 hover:text-brand-200">Entrar</a>
        </p>
        <p class="text-center text-sm text-slate-400">
          Sem conta? <a href="/cliente/cadastro" class="text-brand-300 hover:text-brand-200">Criar conta grátis</a>
        </p>
      </form>

      <!-- Mensagem de sucesso (substitui o form). Anti-enum: mesma copia
           pra email-valido ou fantasma. -->
      <FormError id="sucesso" variant="success" class="mt-6">
        <p class="font-semibold">Link enviado.</p>
        <p class="mt-1">
          Se o email estiver cadastrado, você vai receber um link em alguns
          segundos. Verifique a caixa de entrada (e a pasta de spam).
        </p>
        <p class="mt-3 text-xs text-emerald-200/80">
          O link expira em 15 minutos e só pode ser usado uma vez.
        </p>
      </FormError>
    </Card>
  </Section>

  <script>
    import { solicitarMagicLink } from '~/lib/api';
    import { API_URL } from '~/config';

    const form = document.getElementById('form-magic-link') as HTMLFormElement | null;
    const erroBox = document.getElementById('erro')!;
    const submitBtn = document.getElementById('submit') as HTMLButtonElement | null;
    const sucessoBox = document.getElementById('sucesso')!;

    function mostrarErro(msg: string) {
      erroBox.textContent = msg;
      erroBox.classList.remove('hidden');
    }
    function limparErro() {
      erroBox.textContent = '';
      erroBox.classList.add('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      limparErro();
      submitBtn!.disabled = true;
      submitBtn!.textContent = 'Enviando…';

      const fd = new FormData(form);
      const r = await solicitarMagicLink(
        { email: String(fd.get('email') ?? '').trim() },
        { apiUrl: API_URL },
      );

      const sdk = (window as any).__dsplayground;

      if (r.ok) {
        sdk?.enviarEvento?.('magic_link_solicitado', {});
        // Substitui o form pela mensagem de sucesso (mesma copia anti-enum)
        form.classList.add('hidden');
        sucessoBox.classList.remove('hidden');
        return;
      }

      sdk?.enviarEvento?.('formulario_erro', {
        formulario: 'esqueci-senha', code: r.code, status: r.status,
      });
      mostrarErro(
        r.code === 'RATE_LIMIT_EXCEDIDO'
          ? 'Você pediu muitos links. Espere uns 15 minutos e tente de novo.'
          : r.code === 'REDE'
            ? 'Sem internet agora. Tenta de novo, por favor.'
            : 'Não deu pra enviar o link agora. Tenta de novo.',
      );
      submitBtn!.disabled = false;
      submitBtn!.textContent = 'Enviar link de acesso';
    });
  </script>
</Base>
