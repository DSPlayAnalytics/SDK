---
import Base from '~/layouts/Base.astro';
import Badge from '~/components/ui/Badge.astro';
import Card from '~/components/ui/Card.astro';
import Button from '~/components/ui/Button.astro';

const valores = [
  {
    icon: '🇧🇷',
    titulo: 'Brasil-first',
    descricao: 'Produto pensado pra realidade brasileira: pagamento em real, suporte em português, dado em servidor nacional, conformidade com LGPD por padrão.',
  },
  {
    icon: '👤',
    titulo: 'Você é o cliente',
    descricao: 'A gente cobra pelo serviço, não pelos seus dados. Sem revenda, sem repasse pra rede de propaganda, sem trick.',
  },
  {
    icon: '🔬',
    titulo: 'Pequeno por escolha',
    descricao: 'Equipe enxuta, escopo focado. Sem ruído de produto faz-tudo. Cada feature passa por: "isso resolve uma dor real?".',
  },
  {
    icon: '📖',
    titulo: 'Aberto onde dá',
    descricao: 'SDK público no GitHub Packages. Documentação versionada. Decisões de arquitetura registradas em /seguranca e /docs.',
  },
];
---
<Base
  title="Sobre"
  description="Quem faz, por que faz, pra onde vai."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-brand-950 via-slate-950 to-slate-950"></div>
    <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 sm:py-24">
      <Badge variant="brand" dot>Sobre</Badge>
      <h1 class="mt-6 text-display-sm sm:text-display-md text-white">
        A gente é <span class="bg-gradient-to-r from-brand-300 to-brand-500 bg-clip-text text-transparent">pequeno e contente.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">
        Construímos esse analytics pra resolver um problema que a gente vivia: ferramenta gringa cara, ou ferramenta grátis que vendia o visitante. Faltava uma terceira opção honesta. Aí fizemos.
      </p>
    </div>
  </section>

  <!-- HISTORIA -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">A história curta</h2>
    <div class="mt-6 space-y-4 text-base text-slate-300">
      <p>
        2024: comecei colocando heatmap caseiro num projeto pessoal — só pra ver onde os usuários travavam. Funcionou, mas o painel era só pra mim.
      </p>
      <p>
        2025: dois amigos pediram emprestado. Aí fizemos multi-tenant, separamos buckets, botamos auth direito. Virou um produto pequenininho.
      </p>
      <p>
        2026: abrimos pra clientes piloto. Agora o produto cresce no ritmo de quem usa — não no ritmo de uma roadmap inflada por investidor.
      </p>
    </div>
  </section>

  <!-- VALORES -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Princípios que guiam</h2>
    <p class="mt-3 max-w-2xl text-slate-300">Nem missão, nem manifesto — só os critérios honestos que a gente usa pra decidir o que entra e o que fica de fora.</p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {valores.map((v) => (
        <Card>
          <span class="text-2xl" aria-hidden="true">{v.icon}</span>
          <h3 class="mt-3 text-base font-semibold text-white">{v.titulo}</h3>
          <p class="mt-2 text-sm text-slate-300">{v.descricao}</p>
        </Card>
      ))}
    </div>
  </section>

  <!-- ROADMAP HONESTO -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Pra onde vai</h2>
    <ul class="mt-6 space-y-3 text-sm text-slate-300">
      <li class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
        <strong class="text-white">Curto prazo:</strong> embed nativo (iframe pronto) + CORS dinâmico por cliente + dashboards customizáveis no painel logado.
      </li>
      <li class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
        <strong class="text-white">Médio prazo:</strong> SDK mobile (RN), event replay opcional (com consent), funis e segmentações.
      </li>
      <li class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
        <strong class="text-white">Longo prazo:</strong> abrir mais código, programa formal de bug bounty, parceria com SaaS brasileiros pra integrações nativas.
      </li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <Card>
      <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-bold text-white sm:text-3xl">Quer experimentar?</h2>
          <p class="mt-1 text-slate-300">Plano grátis funciona pra valer. Sem cartão, sem pegadinha.</p>
        </div>
        <div class="flex gap-2">
          <Button href="/cliente/cadastro" variant="primary" data-cta="sobre-cadastro">Criar conta</Button>
          <Button href="/recursos" variant="secondary" data-cta="sobre-recursos">Ver recursos</Button>
        </div>
      </div>
    </Card>
  </section>
</Base>
