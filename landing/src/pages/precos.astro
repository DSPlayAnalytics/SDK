---
import Base from '~/layouts/Base.astro';
import Badge from '~/components/ui/Badge.astro';
import Card from '~/components/ui/Card.astro';
import Button from '~/components/ui/Button.astro';

interface Plano {
  id: 'free' | 'pro' | 'business';
  nome: string;
  publico: string;
  precoMensal: number | null;       // null = sob consulta
  precoAnualPorMes: number | null;  // preco/mes quando paga anual
  destaque: boolean;
  features: string[];
  cta: { href: string; label: string };
}

const planos: Plano[] = [
  {
    id: 'free',
    nome: 'Free',
    publico: 'Pra começar e validar o básico.',
    precoMensal: 0,
    precoAnualPorMes: 0,
    destaque: false,
    features: [
      'Até 100 mil visitas por dia',
      'Seus dados isolados',
      'Painel pronto pra usar',
      'Histórico de 1 semana',
      'Suporte por e-mail',
    ],
    cta: { href: '/cliente/cadastro', label: 'Começar grátis' },
  },
  {
    id: 'pro',
    nome: 'Pro',
    publico: 'Pra sites que cresceram e precisam de mais.',
    precoMensal: 99,
    precoAnualPorMes: 83, // ~16% economia (R$ 996/ano vs R$ 1188)
    destaque: true,
    features: [
      'Até 5 milhões de visitas por dia',
      'Seus dados isolados',
      'Painéis personalizados',
      'Histórico de 3 meses',
      'Suporte prioritário',
      'Limite que cresce com seus picos',
    ],
    cta: { href: '/cliente/cadastro?plano=pro', label: 'Assinar Pro' },
  },
  {
    id: 'business',
    nome: 'Business',
    publico: 'Pra quem precisa de tudo customizado e suporte direto.',
    precoMensal: null,
    precoAnualPorMes: null,
    destaque: false,
    features: [
      'Volume sob medida',
      'Disponibilidade garantida em contrato',
      'Pode rodar dentro da sua infra',
      'Suporte 24/7',
      'Documentação de LGPD e auditoria',
    ],
    cta: { href: 'mailto:contato@dsplayground.com.br?subject=Interesse%20no%20plano%20Business', label: 'Falar com vendas' },
  },
];

// Tabela comparativa — extensao das features dos cards. Inclui itens
// que nao aparecem nos cards pra reduzir poluicao visual.
interface LinhaComparacao {
  feature: string;
  free: string | boolean;
  pro: string | boolean;
  business: string | boolean;
}

const tabelaComparacao: LinhaComparacao[] = [
  { feature: 'Visitas por dia',           free: '100 mil',    pro: '5 milhões',  business: 'Sob medida' },
  { feature: 'Domínios incluídos',        free: '1',          pro: '5',          business: 'Ilimitado' },
  { feature: 'Histórico de dados',        free: '7 dias',     pro: '3 meses',    business: 'Customizado' },
  { feature: 'Painel pronto',             free: true,         pro: true,         business: true },
  { feature: 'Painéis personalizados',    free: false,        pro: true,         business: true },
  { feature: 'Embed do gráfico',          free: false,        pro: true,         business: true },
  { feature: 'Exportar CSV',              free: true,         pro: true,         business: true },
  { feature: 'Multi-tenant isolado',      free: true,         pro: true,         business: true },
  { feature: 'Suporte',                   free: 'E-mail',     pro: 'Prioritário',business: '24/7 + canal direto' },
  { feature: 'SLA contratual',            free: false,        pro: false,        business: true },
  { feature: 'Rodar na sua infra',        free: false,        pro: false,        business: true },
];

const faqBilling = [
  {
    p: 'Posso mudar de plano depois?',
    r: 'A qualquer momento. Sobe (upgrade) já vale no mesmo dia, com cobrança proporcional. Desce (downgrade) entra no próximo ciclo.',
  },
  {
    p: 'Tem multa pra cancelar?',
    r: 'Não. Você cancela quando quiser e segue até o fim do período já pago. Nada de fidelidade obrigatória.',
  },
  {
    p: 'Anual desconta quanto?',
    r: 'Cerca de 16% — você paga o equivalente a 10 meses no Pro anual. Sem letra miúda.',
  },
  {
    p: 'Aceita Pix? Cartão internacional?',
    r: 'Cartão (nacional e internacional) e Pix recorrente. Boleto sob solicitação no plano Business.',
  },
  {
    p: 'Estouro de plano por pico de tráfego me derruba?',
    r: 'Não. Se passar do limite, te avisamos e oferecemos upgrade. A coleta continua durante o pico — a gente prefere te ajudar a crescer do que cobrar surpresa.',
  },
  {
    p: 'Reembolso se eu não gostar?',
    r: 'Reembolso integral nos primeiros 14 dias do primeiro pagamento. Depois, segue até o fim do ciclo.',
  },
];

// Slider da calculadora — resoluçao por degrau (exponencial faz UX
// natural pra quem nao tem nocao de volume). Em milhoes de visitas/mes.
const degraus = [0.05, 0.1, 0.5, 1, 3, 5, 10, 30, 100];
---
<Base
  title="Preços"
  description="Comece grátis com até 100 mil visitas por dia. Mude de plano quando seu site crescer. Sem pegadinha."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h1 class="text-display-sm sm:text-display-md text-white">Planos simples, sem letras miúdas</h1>
    <p class="mt-3 max-w-2xl text-slate-300">Pague pelo tamanho do seu site. Mude de plano quando quiser, sem multa.</p>

    <!-- TOGGLE MENSAL/ANUAL -->
    <div class="mt-8 flex items-center gap-3">
      <div role="group" aria-label="Frequência de cobrança" class="inline-flex rounded-lg border border-slate-800 bg-slate-900 p-1">
        <button
          type="button"
          data-billing="mensal"
          aria-pressed="true"
          class="js-billing-btn rounded-md px-4 py-1.5 text-sm font-medium transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 bg-brand-500 text-white shadow-elev-1"
        >Mensal</button>
        <button
          type="button"
          data-billing="anual"
          aria-pressed="false"
          class="js-billing-btn rounded-md px-4 py-1.5 text-sm font-medium transition text-slate-300 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-400"
        >Anual</button>
      </div>
      <Badge variant="success" dot>economia de 16% no anual</Badge>
    </div>

    <!-- CARDS DE PLANO -->
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {planos.map((plano) => (
        <article
          data-plano={plano.id}
          class:list={[
            'relative flex flex-col rounded-2xl border bg-slate-900/60 p-6 shadow-elev-2 backdrop-blur',
            plano.destaque ? 'border-brand-400 ring-2 ring-brand-500/40' : 'border-slate-800',
          ]}
        >
          {plano.destaque && (
            <span class="absolute -top-3 left-6 rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow-elev-1">
              Mais popular
            </span>
          )}
          <h2 class="text-2xl font-semibold text-white">{plano.nome}</h2>
          <p class="mt-1 text-sm text-slate-400">{plano.publico}</p>
          <div class="mt-4">
            {plano.precoMensal === null ? (
              <p class="flex items-baseline gap-1">
                <span class="text-4xl font-bold text-white">Sob consulta</span>
              </p>
            ) : (
              <>
                <p class="flex items-baseline gap-1">
                  <span class="text-3xl font-bold text-white" aria-hidden="true">R$ </span>
                  <span
                    class="js-preco text-4xl font-bold text-white"
                    data-mensal={plano.precoMensal}
                    data-anual={plano.precoAnualPorMes}
                  >{plano.precoMensal}</span>
                  <span class="text-slate-400">/mês</span>
                </p>
                {plano.precoMensal > 0 && (
                  <p class="js-anual-aviso mt-1 hidden text-xs text-success-300">
                    cobrado anualmente — R$ {plano.precoAnualPorMes! * 12} no ano
                  </p>
                )}
              </>
            )}
          </div>
          <ul class="mt-6 flex-1 space-y-2 text-sm text-slate-300">
            {plano.features.map((f) => (
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 size-4 flex-shrink-0 text-brand-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.5 7.5a1 1 0 01-1.42 0l-3.5-3.5a1 1 0 111.42-1.42l2.79 2.79 6.79-6.79a1 1 0 011.42 0z" clip-rule="evenodd" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <Button
            href={plano.cta.href}
            variant={plano.destaque ? 'primary' : 'secondary'}
            data-cta={`plano-${plano.id}`}
            class="mt-8"
          >
            {plano.cta.label}
          </Button>
        </article>
      ))}
    </div>
  </section>

  <!-- CALCULADORA — slider de eventos/mes recomenda plano. -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Não sabe qual plano cabe em você?</h2>
    <p class="mt-3 text-slate-300">Mexa o controle e a gente sugere onde encaixar.</p>

    <Card class="mt-8">
      <label for="calc-volume" class="block text-sm font-medium text-slate-300">
        Quantas visitas por mês você espera?
      </label>
      <input
        id="calc-volume"
        type="range"
        min="0"
        max={degraus.length - 1}
        step="1"
        value="3"
        class="mt-4 w-full accent-brand-500"
        aria-describedby="calc-resultado"
      />
      <div class="mt-3 flex items-baseline justify-between">
        <p id="calc-volume-label" class="text-3xl font-bold text-white">1 milhão / mês</p>
        <p id="calc-resultado" class="text-sm">
          recomendamos <span class="js-calc-plano font-semibold text-brand-300">Pro</span>
        </p>
      </div>
      <p id="calc-justificativa" class="mt-3 text-sm text-slate-400">
        Volume médio com folga pra picos. Se for crescer rápido ou rodar na sua infra, dá uma olhada no Business.
      </p>
    </Card>
  </section>

  <!-- TABELA COMPARATIVA -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Compare plano por plano</h2>
    <p class="mt-3 text-slate-300">Tudo que cabe ou nao cabe em cada plano, num lugar so.</p>
    <div class="mt-8 overflow-x-auto rounded-xl border border-slate-800 bg-slate-900/40">
      <table class="min-w-full divide-y divide-slate-800 text-sm">
        <thead class="bg-slate-900/60">
          <tr class="text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
            <th class="px-4 py-3">Recurso</th>
            <th class="px-4 py-3">Free</th>
            <th class="px-4 py-3">
              <span class="rounded bg-brand-500/15 px-2 py-0.5 text-brand-200">Pro</span>
            </th>
            <th class="px-4 py-3">Business</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/60">
          {tabelaComparacao.map((linha) => (
            <tr>
              <td class="px-4 py-3 text-slate-200">{linha.feature}</td>
              {(['free', 'pro', 'business'] as const).map((coluna) => {
                const v = linha[coluna];
                if (v === true) {
                  return <td class="px-4 py-3 text-success-300"><span aria-label="Incluído">✓</span></td>;
                }
                if (v === false) {
                  return <td class="px-4 py-3 text-slate-500"><span aria-label="Não incluído">×</span></td>;
                }
                return <td class="px-4 py-3 text-slate-200">{v}</td>;
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- FAQ BILLING -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Sobre cobrança</h2>
    <div class="mt-8 divide-y divide-slate-800 rounded-xl border border-slate-800 bg-slate-900/40">
      {faqBilling.map((item) => (
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-base font-medium text-white hover:bg-slate-900/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-400">
            <span>{item.p}</span>
            <span class="text-slate-400 transition group-open:rotate-180" aria-hidden="true">⌄</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-slate-300">{item.r}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Scripts inline: toggle billing + calculadora. Mantidos no .astro
       pra evitar 2 arquivos extras pra logica trivial. Hashed bundle pelo
       Vite mesmo via inline import? Nao — `is:inline` desliga bundling
       e mantem os scripts coesos com a pagina. Vide AGENTS.md/CLAUDE.md. -->
  <script>
    // ---- Toggle de billing (mensal/anual) ----
    const btnsBilling = Array.from(document.querySelectorAll<HTMLButtonElement>('.js-billing-btn'));
    const precos = Array.from(document.querySelectorAll<HTMLElement>('.js-preco'));
    const avisos = Array.from(document.querySelectorAll<HTMLElement>('.js-anual-aviso'));

    function aplicarBilling(modo: 'mensal' | 'anual') {
      btnsBilling.forEach((b) => {
        const ativo = b.dataset.billing === modo;
        b.setAttribute('aria-pressed', String(ativo));
        b.classList.toggle('bg-brand-500', ativo);
        b.classList.toggle('text-white', ativo);
        b.classList.toggle('shadow-elev-1', ativo);
        b.classList.toggle('text-slate-300', !ativo);
        b.classList.toggle('hover:text-white', !ativo);
      });
      precos.forEach((p) => {
        const valor = modo === 'anual' ? p.dataset.anual : p.dataset.mensal;
        if (valor) p.textContent = valor;
      });
      avisos.forEach((a) => {
        a.classList.toggle('hidden', modo !== 'anual');
      });
    }

    btnsBilling.forEach((b) => {
      b.addEventListener('click', () => aplicarBilling(b.dataset.billing as 'mensal' | 'anual'));
    });

    // ---- Calculadora de plano ----
    const slider = document.getElementById('calc-volume') as HTMLInputElement | null;
    const labelVolume = document.getElementById('calc-volume-label');
    const planoEl = document.querySelector<HTMLElement>('.js-calc-plano');
    const justificativa = document.getElementById('calc-justificativa');
    const degraus = [0.05, 0.1, 0.5, 1, 3, 5, 10, 30, 100]; // milhoes/mes

    function formatarVolume(v: number): string {
      if (v < 1) return `${(v * 1000).toLocaleString('pt-BR')} mil / mês`;
      return `${v.toLocaleString('pt-BR')} milhão${v >= 2 ? 'es' : ''} / mês`;
    }

    function recomendar(v: number): { plano: string; razao: string; cor: string } {
      // 100 mil/dia ≈ 3 mi/mes — corte do free.
      if (v <= 0.1) return {
        plano: 'Free',
        razao: 'Volume baixo, comeca aqui sem pagar nada. Sobe quando crescer.',
        cor: 'text-success-300',
      };
      if (v <= 3) return {
        plano: 'Pro',
        razao: 'Volume médio com folga pra picos. Se for crescer rápido ou rodar na sua infra, dá uma olhada no Business.',
        cor: 'text-brand-300',
      };
      return {
        plano: 'Business',
        razao: 'Volume alto demanda dimensionamento sob medida e SLA. Vamos conversar pra definir um pacote justo.',
        cor: 'text-warning-300',
      };
    }

    function aplicarCalc() {
      if (!slider || !labelVolume || !planoEl || !justificativa) return;
      const idx = parseInt(slider.value, 10);
      const v = degraus[idx] ?? 1;
      labelVolume.textContent = formatarVolume(v);
      const r = recomendar(v);
      planoEl.textContent = r.plano;
      planoEl.className = `js-calc-plano font-semibold ${r.cor}`;
      justificativa.textContent = r.razao;
    }

    if (slider) {
      slider.addEventListener('input', aplicarCalc);
      aplicarCalc(); // inicial
    }
  </script>
</Base>
