---
/**
 * 500 — erro interno generico. Como rodamos SSG (CF Pages), 500 vem
 * via fallback do CDN ou erro do backend. Mensagem honesta + caminho
 * de retentativa.
 */
import Base from '~/layouts/Base.astro';
import Button from '~/components/ui/Button.astro';
import Card from '~/components/ui/Card.astro';
---
<Base
  title="Erro inesperado"
  description="Algo travou do nosso lado. Já estamos vendo o que rolou."
  noindex={true}
>
  <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-4 py-16 text-center sm:px-6">
    <p class="text-display-lg font-bold text-danger-500" aria-hidden="true">500</p>
    <h1 class="mt-4 text-3xl font-bold text-white sm:text-4xl">Algo travou aqui</h1>
    <p class="mt-3 max-w-xl text-slate-300">
      Nem você nem nada que você fez — um pedaço da gente caiu. Já recebemos o aviso. Tenta de novo num instante.
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <button id="recarregar" type="button" class="btn-primary" data-cta="500-recarregar">Recarregar página</button>
      <Button href="/" variant="secondary" data-cta="500-home">Voltar pra home</Button>
    </div>

    <Card class="mt-12 max-w-md text-left">
      <h2 class="text-sm font-semibold text-white">Continua quebrado?</h2>
      <p class="mt-2 text-sm text-slate-300">
        Se persistir por mais de 5 minutos, manda um email pra
        <a href="mailto:contato@dsplayground.com.br?subject=Erro%20500%20persistente" class="text-brand-300 hover:text-brand-200">contato@dsplayground.com.br</a>
        — ajuda a gente a achar o problema.
      </p>
    </Card>
  </section>

  <script>
    document.getElementById('recarregar')?.addEventListener('click', () => {
      window.location.reload();
    });
  </script>
</Base>
