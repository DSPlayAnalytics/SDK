# Variaveis publicas embutidas no bundle Astro em build time.
# Copie para .env (gitignored) e ajuste para o seu ambiente.

# URL do landing — usada em canonical/OG/sitemap. Em prod aponta para apex.
PUBLIC_SITE_URL=https://dsplayground.com.br

# Backend de auth + ingest. Em dev local rode o backend e use http://localhost:5000.
PUBLIC_API_URL=https://api.dsplayground.com.br

# Dashboard logado (subdominio dedicado). Cookie cliente_session viaja entre
# apex e app.X porque backend seta Domain=dsplayground.com.br (var COOKIE_DOMAIN
# no Ansible). Em dev local pode ser http://localhost:5000/cliente/metricas
# (backend serve direto, sem CF Pages).
PUBLIC_DASHBOARD_URL=https://app.dsplayground.com.br/cliente/metricas

# Publishable key da propria landing (dogfood). Vazio = eventos caem no bucket
# default (so faz sentido em dev). Em prod, gere a key com:
#
#   docker compose exec backend python scripts/tenant_admin.py create-key \
#       --slug dsplayground-landing \
#       --nome "DS Playground — Landing" \
#       --ambiente production
#
# e cole o pk_production_... aqui antes de buildar o container.
PUBLIC_PUBLISHABLE_KEY=

# Liga logs do SDK no console (dev/staging). Sempre false em prod.
PUBLIC_DEBUG=false
