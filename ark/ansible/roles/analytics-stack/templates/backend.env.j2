# Gerado pelo Ansible — NAO editar manualmente no host.
# Fonte: ark/ansible/roles/analytics-stack/templates/backend.env.j2
# Variaveis: ark/ansible/group_vars/all.yml + inventory.ini (ambiente)

FLASK_ENV={{ ambiente }}
FLASK_APP=app.py
SECRET_KEY={{ flask_secret_key }}
CORS_ORIGINS={{ cors_origins | join(',') }}

HOST=0.0.0.0
PORT=5000

INFLUXDB_URL={{ influxdb_url }}
INFLUXDB_TOKEN={{ influxdb_token }}
INFLUXDB_ORG={{ influxdb_org }}
INFLUXDB_BUCKET={{ influxdb_bucket }}
INFLUXDB_ENABLED={{ influxdb_enabled | lower }}

ADMIN_API_TOKEN={{ admin_api_token }}

# Resend — magic-link real em prod. Sem RESEND_API_KEY, EmailSender cai em
# stdout (link aparece em `docker logs portifolio-backend`, util pra dev).
# EMAIL_FROM precisa ser dominio verificado na CF DNS + Resend dashboard.
RESEND_API_KEY={{ resend_api_key | default('') }}
EMAIL_FROM={{ email_from | default('no-reply@dsplayground.com.br') }}

# CORS dinamico TTL — tempo entre lookup no Postgres pra cada Origin distinto.
# Default 60s. Se cliente recem-cadastrado precisar de eventos antes, abaixar
# pra 10s (custo: mais hits no DB) ou implementar invalidate explicito apos
# cadastro/adicionar_dominio.
CORS_DINAMICO_TTL_SEGUNDOS={{ cors_dinamico_ttl_segundos | default('60') }}

# Cookie cliente_session — Domain compartilhado entre subdominios same-site
# (api.X seta, app.X/landing leem). Vazio = host-only (legado de apex unico).
COOKIE_DOMAIN={{ cookie_domain | default('') }}

# Magic-link aponta pra api.X (handler /cliente/auth/magic-link/verificar
# vive la). Apos consumir, redireciona pra DASHBOARD_REDIRECT.
DASHBOARD_BASE_URL={{ dashboard_base_url | default('https://api.' + (dominio | default('dsplayground.com.br'))) }}
DASHBOARD_REDIRECT={{ dashboard_redirect | default('https://app.' + (dominio | default('dsplayground.com.br')) + '/cliente/metricas') }}

# Postgres (servico 'postgres' do docker-compose).
# Backend usa role least-privilege `portifolio_app` (CONNECT/USAGE/CRUD em
# public; SEM superuser/createrole/replication). Role superuser `portifolio`
# fica reservada para schema migrations e admin manual via psql/ansible.
# Senha vem do Vault — `postgres_app_password` separada da `postgres_password`
# para permitir rotacao independente.
TENANTS_DATABASE_URL=postgresql://{{ postgres_app_user | default('portifolio_app') }}:{{ postgres_app_password }}@postgres:5432/{{ postgres_db | default('portifolio_auth') }}

# Grafana — usado pelo /cliente/auth/gate pra adicionar user a org
# `cliente_<slug>` em best-effort. Sem isso, user cai na Main Org (vazia)
# e nao ve os dashboards do site dele.
GRAFANA_URL={{ grafana_url_internal | default('http://portifolio-grafana:3000') }}
GRAFANA_ADMIN_USER={{ grafana_admin_user | default('admin') }}
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password }}
GRAFANA_SYNC_TTL_SECONDS={{ grafana_sync_ttl_seconds | default('3600') }}

# JWT do SDK (multi-tenant). Chaves RSA ficam em volume dedicado (backend_keys).
JWT_AUDIENCE={{ jwt_audience | default('api.dsplayground.com.br') }}
JWT_KEYS_DIR=/app/data/keys
SDK_TOKEN_TTL_SECONDS={{ sdk_token_ttl_seconds | default('300') }}
SDK_TOKEN_RATE_LIMIT_PER_KEY={{ sdk_token_rate_limit_per_key | default('5') }}
SDK_AUTH_REQUIRED={{ sdk_auth_required | default('true') | lower }}

TEMPORAL_REALTIME_INTERVAL={{ temporal_realtime_interval | default('5000') }}
TEMPORAL_REGULAR_INTERVAL={{ temporal_regular_interval | default('15000') }}
TEMPORAL_CACHE_SIZE={{ temporal_cache_size | default('1000') }}
TEMPORAL_CLEANUP_INTERVAL={{ temporal_cleanup_interval | default('300') }}

# Archiver R2 — sidecar `analytics-archiver` exporta diario pra Cloudflare R2.
# Endpoint construido em runtime do account_id. Token vem do vault.
R2_ACCOUNT_ID={{ r2_account_id | default('') }}
R2_ACCESS_KEY_ID={{ r2_access_key_id | default('') }}
R2_SECRET_ACCESS_KEY={{ r2_secret_access_key | default('') }}
R2_BUCKET={{ r2_bucket | default('dsplayground-analytics-archive') }}
ARCHIVER_RUN_ON_START={{ archiver_run_on_start | default('false') | lower }}
ARCHIVER_CRON_HORA={{ archiver_cron_hora | default('3') }}
ARCHIVER_CRON_MINUTO={{ archiver_cron_minuto | default('0') }}

# Stripe billing
STRIPE_API_KEY={{ stripe_api_key | default('') }}
STRIPE_PRICE_IDS={{ stripe_price_ids | default('{}') }}
STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret | default('') }}
BILLING_SUCCESS_URL={{ billing_success_url | default('https://dsplayground.com.br/cliente/configuracoes?tab=faturamento&checkout=success') }}
BILLING_CANCEL_URL={{ billing_cancel_url | default('https://dsplayground.com.br/cliente/configuracoes?tab=faturamento&checkout=cancelled') }}
