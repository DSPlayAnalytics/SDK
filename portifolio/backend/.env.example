FLASK_ENV=development
FLASK_APP=app.py

# Seguranca local: altere este valor em qualquer ambiente compartilhado.
SECRET_KEY=dev-local-change-me

# CORS local
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# InfluxDB 2.7 local. Habilite somente quando houver instancia local configurada.
INFLUXDB_ENABLED=false
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=zen
INFLUXDB_BUCKET=portifolio_dev

# Coleta temporal
TEMPORAL_REALTIME_INTERVAL=5000
TEMPORAL_REGULAR_INTERVAL=15000
TEMPORAL_CACHE_SIZE=1000
TEMPORAL_CLEANUP_INTERVAL=300

# Servidor local
HOST=127.0.0.1
PORT=5000

# Autenticacao multi-tenant do SDK (fase 1)
# Audience dos sdk_jwt emitidos; tokens para outros dominios sao rejeitados.
JWT_AUDIENCE=api.dsplayground.local
# Diretorio onde o keypair RSA e persistido (gerado automaticamente no primeiro boot).
JWT_KEYS_DIR=./data/keys
# URL do banco relacional de tenants.
#   Producao/compose: postgresql://portifolio:<senha>@postgres:5432/portifolio_auth
#   Dev local sem Postgres: sqlite:///./data/tenants.db
TENANTS_DATABASE_URL=sqlite:///./data/tenants.db
# Tempo de vida do sdk_jwt em segundos (default 300 = 5 min).
SDK_TOKEN_TTL_SECONDS=300
# Limite de emissoes de sdk_jwt por publishable_key por minuto.
SDK_TOKEN_RATE_LIMIT_PER_KEY=5
# Se true, conexoes Socket.IO sem sdk_jwt valido sao rejeitadas.
# Deixar false ate o SDK ser atualizado para incluir token no handshake.
SDK_AUTH_REQUIRED=false
