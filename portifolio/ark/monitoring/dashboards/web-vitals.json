    {
      "title": "Score Card por metrica (24h) — Bom vs Precisa melhorar vs Ruim",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "__DATASOURCE_UID__" },
      "description": "Cada barra e uma metrica (LCP/INP/CLS). Altura = total de eventos. Cores = rating (verde=bom, amarelo=precisa melhorar, vermelho=ruim). Misturar ratings entre metricas perde sentido — Bom de LCP (<2.5s) e diferente de Bom de INP (<200ms).",
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"__BUCKET__\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"web_vitals\" and r._field == \"valor\")\n  |> filter(fn: (r) => r.device_type != \"bot\")\n  |> group(columns: [\"nome\", \"rating\"])\n  |> count()\n  |> group()\n  |> pivot(rowKey: [\"nome\"], columnKey: [\"rating\"], valueColumn: \"_value\")\n  |> drop(columns: [\"_start\", \"_stop\", \"_field\", \"_measurement\"])"
        }
      ],
      "options": {
        "orientation": "vertical",
        "xField": "nome",
        "stacking": "normal",
        "showValue": "auto",
        "barWidth": 0.7,
        "groupWidth": 0.6,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80,
            "axisPlacement": "auto",
            "axisLabel": "Eventos"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "good" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } },
              { "id": "displayName", "value": "Bom" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "needs-improvement" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } },
              { "id": "displayName", "value": "Precisa melhorar" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "poor" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "displayName", "value": "Ruim" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "nome" },
            "properties": [
              { "id": "displayName", "value": "Metrica" }
            ]
          }
        ]
      }
    },
    {
      "title": "Top 10 paginas mais lentas (LCP p75, 24h)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "__DATASOURCE_UID__" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"__BUCKET__\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"web_vitals\" and r._field == \"valor\" and r.nome == \"LCP\")\n  |> filter(fn: (r) => r.device_type != \"bot\")\n  |> group(columns: [\"page_type\"])\n  |> quantile(q: 0.75)\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 10)"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.page_type}",
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "min": 0,
          "max": 5000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2500 },
              { "color": "red", "value": 4000 }
            ]
          }
        }
      }
    }
