    {
      "title": "LCP media por device_type",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "__DATASOURCE_UID__" },
      "description": "Series por mobile/tablet/desktop. Bots filtrados.",
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"__BUCKET__\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"web_vitals\" and r._field == \"valor\" and r.nome == \"LCP\")\n  |> filter(fn: (r) => r.device_type != \"bot\")\n  |> group(columns: [\"device_type\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.device_type}",
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 12,
            "showPoints": "always",
            "pointSize": 6,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2500 },
              { "color": "red", "value": 4000 }
            ]
          }
        }
      }
    },
    {
      "title": "INP timeline media por device_type",
      "type": "timeseries",
