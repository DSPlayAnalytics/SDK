      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"__BUCKET__\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"web_vitals\" and r._field == \"valor\" and r.nome == \"CLS\")\n  |> group()\n  |> quantile(q: 0.75)"
