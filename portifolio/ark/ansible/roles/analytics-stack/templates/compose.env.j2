# Gerado pelo Ansible — NAO editar manualmente no host.
# Fonte: ark/ansible/roles/analytics-stack/templates/compose.env.j2
# Usado pelo docker-compose.yml da raiz do repositorio.

# InfluxDB
INFLUXDB_INIT_PASSWORD={{ influxdb_init_password }}
INFLUXDB_TOKEN={{ influxdb_token }}

# Postgres (banco relacional de tenants)
POSTGRES_DB={{ postgres_db | default('portifolio_auth') }}
POSTGRES_USER={{ postgres_user | default('portifolio') }}
POSTGRES_PASSWORD={{ postgres_password }}

# Build args do frontend (embutidos no bundle Vite em build time)
VITE_API_URL={{ vite_api_url | default('https://api.' + (dominio | default('dsplayground.com.br'))) }}
VITE_WEBSOCKET_URL={{ vite_websocket_url | default('https://api.' + (dominio | default('dsplayground.com.br'))) }}
VITE_DEBUG={{ vite_debug | default('false') }}
# Publishable key do site `portifolio` (portfolio pessoal Daniel). Sem isso,
# eventos do SDK caem no bucket default em vez de cliente_portifolio.
VITE_PUBLISHABLE_KEY={{ vite_publishable_key | default('') }}

# Build args do landing comercial (embutidos no bundle Astro em build time)
PUBLIC_SITE_URL={{ landing_site_url | default('https://' + (dominio | default('dsplayground.com.br'))) }}
PUBLIC_API_URL={{ landing_api_url | default('https://api.' + (dominio | default('dsplayground.com.br'))) }}
PUBLIC_PUBLISHABLE_KEY={{ landing_publishable_key | default('') }}
PUBLIC_DEBUG={{ landing_debug | default('false') }}

# BuildKit secret consumido pelos Dockerfiles de `frontend` e `landing` para
# baixar @danpqdan/dsplayground-analytics-sdk do GitHub Packages. Compose le
# este .env e propaga pra `secrets.NODE_AUTH_TOKEN.environment` no compose.yml.
# Token de PAT GitHub — NAO commitar. Mode 0640 dono deploy:analytics.
NODE_AUTH_TOKEN={{ node_auth_token }}
